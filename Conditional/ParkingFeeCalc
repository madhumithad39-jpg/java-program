import java.util.Scanner;

public class ParkingFeeCalc {
    public static void main(String[] args) {
        Scanner sc= new Scanner(System.in);
        String location =sc.nextLine();
        double parking = sc.nextDouble();
        sc.nextLine();
        String vehicle = sc.nextLine();
        String membership = sc.nextLine();
        double baseRate= 0;
        double zonePremium =0;
        double vehicleSurcharge = 0;
        double membershipdis=0;
        double dailyCap = 0.0;
        String dailyCapApplied = "No";
        String rateCategory = "";
        if (location.equalsIgnoreCase("Downtown")) {
            zonePremium = 50;
            dailyCap = 150;
            rateCategory = "Premium";
        } 
        
        else if (location.equalsIgnoreCase("Business-District")) {
            zonePremium = 30;
            dailyCap = 120;
            rateCategory = "Premium";
        } 
        
        else if (location.equalsIgnoreCase("Residential")) {
            zonePremium = 0;
            dailyCap = 60;
            rateCategory = "Standard";
        } 
        
        else if (location.equalsIgnoreCase("Airport")) {
            zonePremium = 100;
            dailyCap = 180;
            rateCategory = "Luxury";
        }

        if (vehicle.equalsIgnoreCase("Motorcycle")) {
            vehicleSurcharge = -2;
        } 
        
        else if (vehicle.equalsIgnoreCase("Compact")) {
            vehicleSurcharge = 0;
        } 
        
        else if (vehicle.equalsIgnoreCase("Sedan")) {
            vehicleSurcharge = 0;
        } 
        
        else if (vehicle.equalsIgnoreCase("SUV")) {
            vehicleSurcharge = 3;
        } 
        
        else if (vehicle.equalsIgnoreCase("Oversized")) {
            vehicleSurcharge = 5;
        }

        if (membership.equalsIgnoreCase("None")) {
            membershipdis = 0;
        } 
        
        else if (membership.equalsIgnoreCase("Monthly")) {
            membershipdis= 20;
        } 
        
        else if (membership.equalsIgnoreCase("Annual")) {
            membershipdis= 25;
        } 
        
        else if (membership.equalsIgnoreCase("VIP")) {
            membershipdis= 30;
        }

        double hourlyRate = baseRate * (1 + zonePremium / 100.0) + vehicleSurcharge;
        double calculatedFee = hourlyRate * parking;
        double discountedFee = calculatedFee * (1 - membershipdis / 100.0);

        double finalFee = discountedFee;

        if (parking >= 24) {
            if (discountedFee > dailyCap) {
                finalFee = dailyCap;
                dailyCapApplied = "Yes";
            }
        }

        System.out.println("Location Zone: " + location);
        System.out.println("Parking Duration: " + parking + " hours");
        System.out.println("Vehicle Type: " + vehicle);
        System.out.println("Membership Status: " + membership);
        System.out.println("Base Hourly Rate: $" + baseRate);
        System.out.println("Zone Premium: " + (int)zonePremium + "%");
        System.out.println("Vehicle Size Surcharge: $" + vehicleSurcharge);
        System.out.println("Membership Discount: " + (int)membershipdis+ "%");
        System.out.println("Total Parking Fee: $" + finalFee);
        System.out.println("Daily Cap Applied: " + dailyCapApplied);
        System.out.println("Rate Category: " + rateCategory);
    }
}
