import java.util.Scanner;

public class ParkingFeeCal {

    public static void main(String[] args) {
        Scanner sc= new Scanner(System.in);
        int n= sc.nextInt();
        double TotalRevenue = 0;
        int Hourvehicle =0;
        for (int i =1;i <=n;i++){
            String vehicleType = sc.next();
            double hoursParked = sc.nextDouble();
            double hourlyRate =0;
            double cap =0;
            if(vehicleType.equals("Car")){
                hourlyRate =3.0;
                cap = 30.0;
            }
            else if(vehicleType.equals("Motorcycle")){
                hourlyRate = 2.0;
                cap = 20.0;
            }
            else if(vehicleType.equals("Truck")){
                hourlyRate = 5.0;
                cap = 60.0;
            }
            else if(vehicleType.equals("Bus")){
                hourlyRate = 7.0;
                cap = 100.0;
            }
            double fee = hoursParked*hourlyRate;
            boolean capApplied = false;
            if(fee>cap){
                fee = cap ;
                capApplied = true;
            }
            if(hoursParked>8){
                Hourvehicle++;
            }
            TotalRevenue = TotalRevenue +fee;
            System.out.println("Vehicle"+i+":"+vehicleType);
            System.out.println("Hours Parked : "+ hoursParked);
            System.out.println("Hourly Rate : $ "+ hourlyRate);
            System.out.println("Parking Fee  :  $ "+ fee);
            System.out.println("Cap Applied : "+(capApplied ? "Yes":"No"));
        }
        double AverageFee = TotalRevenue /n;
        System.out.println("Total Vehicle : "+n);
        System.out.println("Total Revenue : $ "+TotalRevenue);
        System.out.printf("Average Fee : $%.2f\n",AverageFee);
        System.out.println("Peak Hour Vehicle (>8 Hours) : "+ Hourvehicle);
    }
}
